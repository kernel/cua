{
  "name": "@onkernel/cua-bench",
  "version": "0.1.0",
  "description": "Extensible web-agent benchmark runner for Kernel cloud browsers and the cua agent loop",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kernel/cua.git",
    "directory": "packages/bench"
  },
  "bugs": {
    "url": "https://github.com/kernel/cua/issues"
  },
  "homepage": "https://github.com/kernel/cua/tree/main/packages/bench#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "cua-bench": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "build": "tsdown && chmod +x dist/cli.js",
    "clean": "tsc -b --clean && rm -rf dist dist-tsc",
    "test": "vitest --run",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@onkernel/cua-agent": "0.3.5",
    "@onkernel/cua-ai": "0.3.2",
    "@onkernel/sdk": "0.49.0"
  },
  "devDependencies": {
    "tsdown": "^0.22.2",
    "vitest": "^3.2.4"
  }
}
