{
  "name": "@onkernel/cua-ai",
  "version": "0.1.0",
  "description": "Kernel-curated computer-use model access built on pi-ai",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "example:quickstart": "tsx examples/quickstart.ts",
    "test": "vitest --run"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "0.67.6",
    "@sinclair/typebox": "0.34.49",
    "@tzafon/lightcone": "^0.7.0",
    "openai": "^6.26.0"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
